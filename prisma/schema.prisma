generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int       @id @default(autoincrement())
  name             String
  email            String    @unique
  password         String
  role             Role      @default(USER)

  isPremium        Boolean   @default(false)
  premiumExpiresAt DateTime?

  profileImage     String?
  avatarPreset     String    @default("boy")

  xp               Int       @default(0)
  level            Int       @default(1)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt

  premiumOrders    PremiumOrder[]
  favoriteMangas   FavoriteManga[]
  readingHistories ReadingHistory[]
}

model PremiumOrder {
  id     Int @id @default(autoincrement())
  userId Int

  months Int    @default(1)
  amount Int
  status String @default("PENDING")

  invoiceId String? @unique
  qrText    String?

  wirePaymentIntentId String? @unique
  wireClientSecret    String?
  wireStatus          String?
  wireNextAction      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  paidAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([wireStatus])
}

model Comic {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  description String
  coverImage  String
  bannerImage String?
  author      String?

  genre       String   @default("Бусад")
  genre2      String?
  genre3      String?

  status      String   @default("ONGOING")
  views       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  chapters         Chapter[]
  favoriteBy       FavoriteManga[]
  readingHistories ReadingHistory[]
}

model FavoriteManga {
  id        Int      @id @default(autoincrement())
  userId    Int
  comicId   Int
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  comic Comic @relation(fields: [comicId], references: [id], onDelete: Cascade)

  @@unique([userId, comicId])
  @@index([userId])
  @@index([comicId])
}

model Chapter {
  id        Int      @id @default(autoincrement())
  title     String
  number    Int
  comicId   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  comic            Comic            @relation(fields: [comicId], references: [id], onDelete: Cascade)
  images           ChapterImage[]
  readingHistories ReadingHistory[]

  @@unique([comicId, number])
  @@index([comicId])
}

model ChapterImage {
  id        Int    @id @default(autoincrement())
  imageUrl  String
  order     Int
  chapterId Int

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
}

model ReadingHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  comicId   Int
  chapterId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comic   Comic   @relation(fields: [comicId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
  @@index([comicId])
  @@index([chapterId])
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      OtpType
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([code])
  @@index([type])
}

enum Role {
  USER
  EDITOR
  ADMIN
}

enum OtpType {
  REGISTER
  RESET_PASSWORD
}